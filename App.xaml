<Application x:Class="FluidDecks.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FluidDecks"
             xmlns:converters="clr-namespace:FluidDecks.UI.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI Dictionaries -->
                <ui:ThemesDictionary xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" Theme="Dark" />
                <ui:ControlsDictionary xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" />
                
                <!-- FluidDecks Animations -->
                <ResourceDictionary Source="FluidAnimations.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
