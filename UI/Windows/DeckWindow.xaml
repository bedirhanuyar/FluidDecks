<Window x:Class="FluidDecks.UI.Windows.DeckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FluidDecks.UI.Controls"
        mc:Ignorable="d"
        Title="DeckWindow" 
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Width="80" Height="110" AllowDrop="True"
        Left="{Binding X, Mode=TwoWay}" Top="{Binding Y, Mode=TwoWay}">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0" ResizeBorderThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid x:Name="MainGrid" Margin="0">
        <controls:DeckPanel />
    </Grid>
</Window>
