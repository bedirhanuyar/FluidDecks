<ui:FluentWindow x:Class="FluidDecks.UI.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to FluidDecks" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True"
        Topmost="True">
    
    <!-- Purple Glassmorphism Theme Background -->
    <Window.Background>
        <SolidColorBrush Color="#2B1A3A" Opacity="0.85"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ui:TitleBar Title="Welcome to FluidDecks" Grid.Row="0" Background="Transparent" Foreground="#F0E6FF" />

        <Grid Grid.Row="1" Margin="40,20,40,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <Image Source="pack://application:,,,/Icon75.png" Width="140" Height="140" VerticalAlignment="Top" Margin="0,20,30,0" RenderOptions.BitmapScalingMode="HighQuality"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Welcome to FluidDecks!" FontSize="32" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                
                <TextBlock Text="Your desktop, reimagined with fluid interactions and physics." FontSize="16" Foreground="#D0C0E0" TextWrapping="Wrap" Margin="0,0,0,24"/>

                <Border Background="#1A000000" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Quick Tips:" FontWeight="SemiBold" FontSize="18" Foreground="#F0E6FF" Margin="0,0,0,12"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="TapSingle24" Foreground="#B090D0" Margin="0,0,12,0"/>
                            <TextBlock Text="Double Click to expand any virtual folder." Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="Drag24" Foreground="#B090D0" Margin="0,0,12,0"/>
                            <TextBlock Text="Drag and Drop to move folders around your screen." Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="Settings24" Foreground="#B090D0" Margin="0,0,12,0"/>
                            <TextBlock Text="Right Click the system tray icon to access Settings." Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <ui:SymbolIcon Symbol="Flash24" Foreground="#B090D0" Margin="0,0,12,0"/>
                            <TextBlock Text="Enable Physics in Settings to throw folders with inertia!" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#10FFFFFF" Padding="24,16,24,16" BorderThickness="0,1,0,0" BorderBrush="#20FFFFFF">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Get Started" Width="140" Height="36" Click="GetStarted_Click" 
                        Background="#8A2BE2" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
